datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")

}
generator client {
  provider = "prisma-client-js"
}
// 📚 MODELO DA BIBLIOTECA DE PROMPTS
model Prompt {
  id        String   @id @default(uuid())
  titulo    String
  tipo      String   // "Visual" ou "Falado"
  fragmento String   @db.Text
  createdAt DateTime @default(now())

  @@map("prompts") // Cria a tabela no banco com nome minúsculo
}

// 🎬 MODELO DO HISTÓRICO DE GERAÇÕES UGC
model VideoHistory {
  id              String   @id @default(uuid())
  userId          String
  produto         String
  avatarDescricao String   @db.Text
  ambiente        String
  tipoVideo       String
  duracao         String
  promptsGerados  Json     // Salva o array de cenas completo retornado pela OpenAI
  createdAt       DateTime @default(now())

  @@map("video_histories")
}

model Niche {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model User {
  id        String      @id // Esse ID vem direto do UUID do Auth do Supabase
  email     String      @unique
  name      String?
  credits   Int         @default(10) // Já damos 10 créditos grátis de largada!
  createdAt DateTime    @default(now())
  
  // 🔥 Relacionamentos Ativos!
  config    UserConfig?

  @@map("users")
}

// ⚙️ MODELO DE CONFIGURAÇÕES PRIVADAS DO USUÁRIO
model UserConfig {
  id         String   @id @default(uuid())
  openaiKey  String?  
  elevenKey  String?  
  brandVoice String?  @db.Text // Campo de texto longo para o contexto da marca
  
  // 🔒 Amarração de segurança Relacional (1 para 1)
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt  DateTime @updatedAt

  @@map("user_configs")
}